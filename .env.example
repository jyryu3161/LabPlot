# Database (compose injects DATABASE_URL pointing at labplot-db)
DATABASE_URL=postgresql://labplot:labplot@labplot-db:5432/labplot

# Auth / JWT
JWT_SECRET=change-me-use-openssl-rand-hex-64
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Root admin (seeded on first startup)
ROOT_EMAIL=root
ROOT_PASSWORD=root

# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
AI_ENABLED=true

# Uploads
MAX_UPLOAD_SIZE_MB=50
