# Database (compose injects DATABASE_URL pointing at labplot-db)
POSTGRES_PASSWORD=change-me-use-openssl-rand-hex-32
DATABASE_URL=postgresql://labplot:change-me-use-openssl-rand-hex-32@labplot-db:5432/labplot
APP_BASE_URL=https://labplotai.com
ALLOWED_ORIGINS=https://labplotai.com,https://www.labplotai.com

# Auth / JWT
JWT_SECRET=change-me-use-openssl-rand-hex-64
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Root admin (seeded on first startup)
ROOT_EMAIL=admin@labplotai.com
ROOT_PASSWORD=change-me-use-a-long-admin-password

# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
AI_ENABLED=true

# Uploads
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=/app/backend/private/uploads
FIGURES_DIR=/app/backend/static/figures
DATA_ENCRYPTION_KEY=change-me-use-openssl-rand-base64-32
DATA_ENCRYPTION_PREVIOUS_KEYS=

# Optional error monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=

# Password reset email
PASSWORD_RESET_EXPIRE_MINUTES=30
PASSWORD_RESET_LOG_TOKEN=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@labplotai.com

# Optional analytics
NEXT_PUBLIC_GA_ID=
