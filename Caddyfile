# Shared routing
(labplot) {
	encode zstd gzip
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' https://www.google-analytics.com https://region1.google-analytics.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
	}
	handle /api/* {
		reverse_proxy labplot-backend:8000
	}
	handle /static/uploads/* {
		respond 404
	}
	handle /static/figures/* {
		header Cache-Control "public, max-age=31536000, immutable"
		reverse_proxy labplot-backend:8000
	}
	handle /static/* {
		header Cache-Control "public, max-age=3600"
		reverse_proxy labplot-backend:8000
	}
	handle /docs* {
		reverse_proxy labplot-backend:8000
	}
	handle /openapi.json {
		reverse_proxy labplot-backend:8000
	}
	handle {
		reverse_proxy labplot-frontend:3000
	}
}

# Main domain with Caddy automatic HTTPS
labplotai.com {
	import labplot
}

# Permanent redirect from www to apex
www.labplotai.com {
	redir https://labplotai.com{uri} permanent
}
