# Shared routing
(labplot) {
	encode zstd gzip
	handle /api/* {
		reverse_proxy labplot-backend:8000
	}
	handle /static/figures/* {
		header Cache-Control "public, max-age=31536000, immutable"
		reverse_proxy labplot-backend:8000
	}
	handle /static/* {
		header Cache-Control "public, max-age=3600"
		reverse_proxy labplot-backend:8000
	}
	handle /docs* {
		reverse_proxy labplot-backend:8000
	}
	handle /openapi.json {
		reverse_proxy labplot-backend:8000
	}
	handle {
		reverse_proxy labplot-frontend:3000
	}
}

# Main domain with Caddy automatic HTTPS
labplotai.com {
	import labplot
}

# Permanent redirect from www to apex
www.labplotai.com {
	redir https://labplotai.com{uri} permanent
}
